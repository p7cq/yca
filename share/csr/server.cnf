# openssl req config for a yca server CSR. Only the fields yca honors are
# requested: a CN-only subject (an ASCII hostname for the server profile) and
# supported SANs (dns, email, IP). Anything else in a CSR is ignored - the CA
# dictates the certificate profile.
#
# Usage:
#   openssl ecparam -genkey -name prime256v1 -noout -out server.key
#   openssl req -new -key server.key -config server.cnf -out server.csr

[req]
prompt             = no
distinguished_name = dn
req_extensions     = ext

[dn]
CN = server.example.ca

[ext]
# DNS:<CN> is always added by the CA; list only the extra names here.
subjectAltName = DNS:example.ca
